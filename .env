# =====================================
# 数据社区平台 - 环境变量配置
# =====================================

# 主框架
VITE_PORTAL_PORT=8000
VITE_PORTAL_HOST=localhost

# 子应用端口配置
VITE_RISK_PORT=8001
VITE_MKT_PORT=8002
VITE_DEX_PORT=8003
VITE_DMT_PORT=8004
VITE_ADMIN_PORT=8005

# 独立服务（不参与统一启动）
VITE_COMMUNITY_PORT=3001

# API基础路径
VITE_API_BASE=/api
VITE_MOCK_API=true

# 微前端配置
VITE_QIANKUN_MODE=true
VITE_SANDBOX=false

# 开发配置
VITE_DEV_MODE=true
VITE_LOG_LEVEL=debug
