{
  "root": true,
  "parser": "vue-eslint-parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "parser": "@typescript-eslint/parser",
    "extraFileExtensions": [".vue"]
  },
  "extends": [
    "eslint:recommended",
    "plugin:vue/vue3-recommended",
    "plugin:@typescript-eslint/recommended"
  ],
  "plugins": ["vue", "@typescript-eslint"],
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "ignorePatterns": ["dist/", "node_modules/"],
  "rules": {
    "vue/multi-word-component-names": "off",
    "vue/no-unused-vars": "off",
    "vue/no-unused-components": "off",
    "vue/require-default-prop": "off",
    "vue/require-prop-types": "off",
    "vue/prop-name-casing": "off",
    "vue/component-name-in-template-casing": "off",
    "vue/no-side-effects-in-computed-properties": "off",
    "vue/no-mutating-props": "off",
    "no-console": "off",
    "@typescript-eslint/no-unused-vars": "off",
    "@typescript-eslint/no-explicit-any": "off",
    "@typescript-eslint/explicit-function-return-type": "off",
    "@typescript-eslint/explicit-module-boundary-types": "off",
    "@typescript-eslint/no-non-null-assertion": "off",
    "@typescript-eslint/ban-ts-comment": "off",

    /* 钟离：Vue Router path 辅助检查
     * ⚠️ 已知局限：selector 无法区分 root path 和 children path
     * 会误报 children 中相对路径（OK，不报错），会漏报 root 中缺 / 的路径
     * 主要保障：单元测试 tests/router/risk-app.spec.ts（验证 children 相对路径正确性）
     * 运行时保障：createRouter → tokenizePath 会校验，缺 / 会在生产报 error
     */
    "no-restricted-syntax": ["warn", {
      "selector": "Property[key.name='path'] > Literal[value!=''][value!='/']",
      "message": "Vue Router path 应以 / 开头。根级必须，children 使用相对路径。当前: \"{{ value }}\""
    }]
  }
}
